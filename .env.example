# Copy to .env and fill in. The .env file is gitignored.

# ── Voice generation (ElevenLabs) ─────────────────────────────────────
# Used by lib/shared.py:generate_voice_with_timestamps for Segment 2 VO.
ELEVENLABS_API_KEY=

# ── Image generation (Gemini) ─────────────────────────────────────────
# Optional — only required if you let the pipeline generate background
# stills via Gemini variants. If you set `still_path:` in your config to
# an existing image, this is not needed.
GEMINI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────
# Used by upcoming scripture/script generation utilities (Claude API).
ANTHROPIC_API_KEY=

# ── Scripture API ─────────────────────────────────────────────────────
# Pending: choose between bible-api.com (no key, public-domain only),
# ESV API (free w/ key + rate limits), or api.bible (broader catalog).
SCRIPTURE_API_KEY=
