# Copy to .env and fill in. The .env file is gitignored.

# ── Voice generation (ElevenLabs) ─────────────────────────────────────
# Used by lib/shared.py:generate_voice_with_timestamps for Segment 2 VO.
ELEVENLABS_API_KEY=

# ── Image generation (Gemini) ─────────────────────────────────────────
# Optional — only required if you let the pipeline generate background
# stills via Gemini variants. If you set `still_path:` in your config to
# an existing image, this is not needed.
GEMINI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────
# Used by upcoming scripture/script generation utilities (Claude API).
ANTHROPIC_API_KEY=

# ── Scripture API ─────────────────────────────────────────────────────
# Pending: choose between bible-api.com (no key, public-domain only),
# ESV API (free w/ key + rate limits), or api.bible (broader catalog).
SCRIPTURE_API_KEY=

# ── Google Drive upload (scripts/upload_to_drive.py) ──────────────────
# Drive folder where rendered MP4s land. The service account
# (media-pipeline-bot@ukpresenter.iam.gserviceaccount.com) must be
# granted Editor access on this folder.
GDRIVE_FOLDER_ID=1Vd-hpfYAlVWqEYFjp3RRQC_R7o1Uurpm

# Service-account credentials. Use ONE of the following locally:
#   GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/gdrive-sa.json
# or place the key at  secrets/gdrive-sa.json  (gitignored).
# In GitHub Actions the key is injected as the GDRIVE_SA_KEY env var
# from the repo secret of the same name (raw JSON content).
GOOGLE_APPLICATION_CREDENTIALS=
